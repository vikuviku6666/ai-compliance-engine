OPENROUTER_API_KEY=sk-or-v1-your-key-here

DATABASE_URL=postgresql://postgres:password@localhost/compliance

NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password

# Neo4j connection pooling and timeout configuration
NEO4J_POOL_SIZE=50
NEO4J_CONNECTION_TIMEOUT=30.0
NEO4J_SOCKET_TIMEOUT=30.0
NEO4J_QUERY_TIMEOUT=60.0

# Neo4j SSL/TLS configuration (optional)
# NEO4J_ENCRYPTED=false
# NEO4J_TRUST=TRUST_SYSTEM_CA_SIGNED_CERTIFICATES

# Optional: suppress HuggingFace Hub warnings
HF_HUB_DISABLE_IMPLICIT_TOKEN=1
HUGGINGFACE_HUB_VERBOSITY=error
