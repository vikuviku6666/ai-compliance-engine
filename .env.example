OPENROUTER_API_KEY=sk-or-v1-your-key-here

DATABASE_URL=postgresql://postgres:password@localhost/compliance

NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password

# Neo4j connection configuration
NEO4J_POOL_SIZE=50
NEO4J_CONNECTION_TIMEOUT=30.0

# Optional: Query timeout (not enforced by driver, for app-level use)
NEO4J_QUERY_TIMEOUT=60.0

# Optional: Enable encrypted connections
NEO4J_ENCRYPTED=false

# Optional: suppress HuggingFace Hub warnings
HF_HUB_DISABLE_IMPLICIT_TOKEN=1
HUGGINGFACE_HUB_VERBOSITY=error
